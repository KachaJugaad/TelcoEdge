    {
      "id": 9,
      "title": "BER Comparison — Fixed MCS vs WeatherRAN Adaptive",
      "type": "barchart",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 11 },
      "datasource": {
        "type": "marcusolsson-json-datasource",
        "uid": "${DS_WEATHERRAN-JSON}"
      },
      "targets": [
        {
          "refId": "A",
          "fields": [
            { "jsonPath": "$.ber.baseline", "type": "number", "language": "jsonpath" },
            { "jsonPath": "$.ber.adaptive", "type": "number", "language": "jsonpath" }
          ],
          "method": "GET",
          "urlPath": "/metrics"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "sci",
          "custom": {
            "fillOpacity": 80,
            "gradientMode": "scheme",
            "lineWidth": 1
          },
          "color": { "mode": "palette-classic" }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "baseline" },
            "properties": [
              { "id": "displayName", "value": "Fixed MCS (Baseline)" },
              { "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "adaptive" },
            "properties": [
              { "id": "displayName", "value": "WeatherRAN Adaptive" },
              { "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }
            ]
          }
        ]
      },
      "options": {
        "orientation": "horizontal",
        "barWidth": 0.5,
        "groupWidth": 0.7,
        "showValue": "always",
        "stacking": "none",
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "single" },
        "xTickLabelRotation": 0
      }
    },
    {
      "id": 10,
      "title": "Policy Action Log",
      "type": "table",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 11 },
      "datasource": {
        "type": "marcusolsson-json-datasource",
        "uid": "${DS_WEATHERRAN-JSON}"
      },
      "targets": [
        {
          "refId": "A",
          "fields": [
            { "jsonPath": "$[*].time", "type": "string", "language": "jsonpath" },
            { "jsonPath": "$[*].rain_mm_hr", "type": "number", "language": "jsonpath" },
            { "jsonPath": "$[*].source", "type": "string", "language": "jsonpath" },
            { "jsonPath": "$[*].action", "type": "string", "language": "jsonpath" },
            { "jsonPath": "$[*].mcs_baseline", "type": "number", "language": "jsonpath" },
            { "jsonPath": "$[*].mcs_adjusted", "type": "number", "language": "jsonpath" },
            { "jsonPath": "$[*].ber_baseline", "type": "string", "language": "jsonpath" },
            { "jsonPath": "$[*].ber_adaptive", "type": "string", "language": "jsonpath" },
            { "jsonPath": "$[*].improvement_pct", "type": "string", "language": "jsonpath" }
          ],
          "method": "GET",
          "urlPath": "/action-log"
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "time" },
            "properties": [
              { "id": "displayName", "value": "Time" },
              { "id": "custom.width", "value": 180 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "rain_mm_hr" },
            "properties": [
              { "id": "displayName", "value": "Rain (mm/hr)" }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "action" },
            "properties": [
              { "id": "displayName", "value": "Policy Action" },
              { "id": "custom.width", "value": 250 }
            ]
          }
        ]
      },
      "options": {
        "showHeader": true,
        "sortBy": [{ "displayName": "Time", "desc": true }],
        "footer": { "show": false }
      }
    }
  ],
  "refresh": "10s",
