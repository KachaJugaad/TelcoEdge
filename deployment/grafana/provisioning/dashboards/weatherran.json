      ],
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "max": 28,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": null }
            ]
          },
          "displayName": "Baseline MCS"
        },
        "overrides": []
      },
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "center",
        "textMode": "value_and_name",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      }
    },
