{
  "annotations": {
    "list": []
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "id": 1,
      "title": "WeatherRAN Demo — Phase 1",
      "type": "text",
      "gridPos": { "h": 3, "w": 24, "x": 0, "y": 0 },
      "options": {
        "mode": "markdown",
        "content": "# WeatherRAN — First Weather-Predictive O-RAN xApp in Canada (Simulated)\nLive MSC GeoMet weather data feeds into MCS policy which pre-adjusts modulation before RF degrades. BER improvement shown vs fixed-MCS baseline.\n\n**Data source:** Environment Canada MSC GeoMet (anonymous, no API key) | **Channel model:** 3GPP TR 38.901 RMa (prairie) | **Policy:** E2SM-RC v1.03 MCS override"
      }
    },
    {
      "id": 2,
      "title": "Rain Intensity (mm/hr)",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 6, "x": 0, "y": 3 },
      "datasource": {
        "type": "marcusolsson-json-datasource",
        "uid": "${DS_WEATHERRAN-JSON}"
      },
      "targets": [
        {
          "refId": "A",
          "fields": [
            { "jsonPath": "$.weather.rain_mm_per_hr", "type": "number" }
          ],
          "method": "GET",
          "urlPath": "/metrics"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "max": 50,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "#EAB839", "value": 5 },
              { "color": "orange", "value": 15 },
              { "color": "red", "value": 25 }
            ]
          },
          "unit": "mm/hr",
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "showThresholdLabels": true,
        "showThresholdMarkers": true
      }
    },
    {
      "id": 3,
      "title": "MCS Index — Baseline (Fixed)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 6, "y": 3 },
